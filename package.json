{
  "name": "wayweft",
  "version": "0.1.0",
  "description": "TypeScript-first AST-based refactoring opportunity engine for single-package repos and monorepos",
  "license": "AGPL-3.0-only",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "wayweft": "./dist/cli.js"
  },
  "files": [
    "dist",
    "tools/wayweft-skill"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean",
    "dev": "tsx src/cli.ts",
    "docs:dev": "npm --prefix docs run dev",
    "docs:build": "npm --prefix docs run build",
    "docs:preview": "npm --prefix docs run preview",
    "test": "vitest run",
    "lint": "tsc --noEmit",
    "prepare": "npm run build"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "fast-glob": "^3.3.3",
    "js-yaml": "^4.1.0",
    "minimatch": "^10.0.1",
    "picocolors": "^1.1.1",
    "ts-morph": "^24.0.0",
    "typescript": "^5.8.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "vitest": "^3.0.8"
  }
}
