---
import "../styles/brand.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Wayweft</title>
    <meta
      name="description"
      content="Wayweft is a codebase intelligence layer for AI-assisted development."
    />
  </head>
  <body class="landing-shell">
    <div class="landing-bg" aria-hidden="true">
      <span class="trace trace-a"></span>
      <span class="trace trace-b"></span>
      <span class="trace trace-c"></span>
    </div>

    <header class="landing-header">
      <a href="/" class="brand-lockup">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 48 48" role="img" focusable="false">
            <path d="M6 12c4 0 6 2 8 8l4 12c1.2 3.6 2.7 4 6 4 2.8 0 4.2-.9 5.4-4.7L36 12c1.5 5 3 10 4.4 15 1 3.4 2 5.2 4.6 5.2" />
            <path d="M6 36c4 0 5.5-1.7 6.7-5.3L18 12c1.4 4.5 2.8 9.1 4.3 13.7 1.3 4.1 2.7 6.3 5.7 6.3 2.7 0 4.1-1.8 5.2-5.8L38 12c1.3 3.7 2.3 6.1 4 7.8" />
          </svg>
        </span>
        <span class="brand-wordmark">Wayweft</span>
      </a>
      <nav class="landing-nav">
        <a href="/docs/">Docs</a>
        <a href="/docs/getting-started/">Getting Started</a>
        <a href="https://github.com/sachaarbonel/wayweft">GitHub</a>
      </nav>
    </header>

    <main class="landing-main">
      <section class="hero-grid">
        <div class="hero-copy">
          <p class="eyebrow">Woven signal</p>
          <h1>Codebase intelligence for AI-assisted development.</h1>
          <p class="hero-body">
            Wayweft helps teams review changes after a Claude or Codex session,
            detect duplication and refactor drift, preserve codebase context,
            and carry knowledge forward across sessions.
          </p>
          <div class="hero-actions">
            <a class="primary-action" href="/docs/">Read the docs</a>
            <a class="secondary-action" href="/docs/getting-started/">Start here</a>
          </div>
        </div>

        <div class="hero-panel">
          <div class="panel-traces" aria-hidden="true">
            <span></span>
            <span></span>
            <span></span>
          </div>
          <div class="panel-copy">
            <p class="panel-label">Positioning</p>
            <h2>Post-session review with durable continuity.</h2>
            <p>
              Built for serious engineering teams that need validation
              guidance, cleanup workflows, and codebase memory without turning
              the stack into a generic AI platform.
            </p>
          </div>
        </div>
      </section>

      <section class="feature-grid">
        <article>
          <p class="feature-kicker">Review</p>
          <h3>Changed-scope analysis</h3>
          <p>Scan the workspace, a package, or changed files to surface structural drift before it spreads.</p>
        </article>
        <article>
          <p class="feature-kicker">Continuity</p>
          <h3>Codebase memory</h3>
          <p>Carry guidance and review context across sessions with portable skills and repo-level workflow docs.</p>
        </article>
        <article>
          <p class="feature-kicker">Cleanup</p>
          <h3>Safe fixes first</h3>
          <p>Preview low-risk rewrites with dry-run workflows before touching the target repository.</p>
        </article>
      </section>

      <section class="command-band">
        <div>
          <p class="feature-kicker">CLI</p>
          <h3>Start with one command.</h3>
        </div>
        <pre><code>wayweft scan --scope workspace --format text</code></pre>
      </section>
    </main>
  </body>
</html>

<style>
  :global(:root) {
    color-scheme: light;
  }

  .landing-shell {
    min-height: 100vh;
    margin: 0;
    color: var(--wayweft-ink);
    background:
      radial-gradient(circle at top left, rgba(181, 148, 97, 0.12), transparent 26%),
      radial-gradient(circle at top right, rgba(88, 129, 132, 0.14), transparent 34%),
      linear-gradient(180deg, #f7f1e7 0%, #f1e7d8 100%);
  }

  .landing-bg {
    position: fixed;
    inset: 0;
    pointer-events: none;
    overflow: hidden;
  }

  .trace {
    position: absolute;
    display: block;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(88, 129, 132, 0.55), rgba(181, 148, 97, 0.6), transparent);
  }

  .trace-a {
    top: 19%;
    left: -6%;
    width: 48%;
    transform: rotate(8deg);
  }

  .trace-b {
    top: 43%;
    right: -10%;
    width: 52%;
    transform: rotate(-12deg);
  }

  .trace-c {
    bottom: 16%;
    left: 12%;
    width: 38%;
  }

  .landing-header,
  .landing-main {
    position: relative;
    z-index: 1;
    width: min(1120px, calc(100% - 2rem));
    margin: 0 auto;
  }

  .landing-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 1.25rem 0;
  }

  .brand-lockup {
    display: inline-flex;
    align-items: center;
    gap: 0.85rem;
    color: inherit;
    text-decoration: none;
  }

  .brand-mark {
    display: inline-flex;
    width: 2.6rem;
    height: 2.6rem;
    align-items: center;
    justify-content: center;
    border: 1px solid rgba(26, 31, 53, 0.14);
    border-radius: 0.8rem;
    background: rgba(243, 235, 220, 0.78);
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.55);
  }

  .brand-mark svg {
    width: 1.65rem;
    height: 1.65rem;
    stroke: currentColor;
    stroke-width: 2.4;
    fill: none;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  .brand-wordmark {
    font-family: var(--wayweft-font-heading);
    font-size: 1.35rem;
    font-weight: 560;
    letter-spacing: -0.03em;
  }

  .landing-nav {
    display: flex;
    gap: 1.25rem;
    flex-wrap: wrap;
  }

  .landing-nav a {
    color: var(--wayweft-ink);
    text-decoration: none;
    font-weight: 600;
  }

  .landing-main {
    padding: 3.5rem 0 4rem;
  }

  .hero-grid {
    display: grid;
    gap: 2rem;
    align-items: center;
  }

  .eyebrow,
  .feature-kicker,
  .panel-label {
    margin: 0 0 0.7rem;
    color: var(--wayweft-brass);
    text-transform: uppercase;
    letter-spacing: 0.14em;
    font-weight: 700;
    font-size: 0.8rem;
  }

  h1,
  h2,
  h3 {
    margin: 0;
  }

  .hero-copy h1 {
    max-width: 11ch;
    font-size: clamp(3rem, 8vw, 5.8rem);
    line-height: 0.96;
  }

  .hero-body,
  .panel-copy p,
  .feature-grid p {
    max-width: 42rem;
    font-size: 1.08rem;
    line-height: 1.7;
    color: var(--sl-color-gray-1);
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 1.75rem;
  }

  .hero-actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3rem;
    padding: 0 1.15rem;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 700;
  }

  .primary-action {
    background: var(--wayweft-ink);
    color: var(--wayweft-paper);
  }

  .secondary-action {
    color: var(--wayweft-ink);
    border: 1px solid rgba(26, 31, 53, 0.16);
    background: rgba(243, 235, 220, 0.62);
  }

  .hero-panel,
  .command-band,
  .feature-grid article {
    border: 1px solid rgba(26, 31, 53, 0.12);
    background:
      linear-gradient(135deg, rgba(255, 255, 255, 0.44), rgba(255, 255, 255, 0.14)),
      rgba(243, 235, 220, 0.72);
    box-shadow: 0 20px 50px rgba(26, 31, 53, 0.06);
  }

  .hero-panel {
    display: grid;
    gap: 1.5rem;
    padding: 1.5rem;
    border-radius: 1.6rem;
  }

  .panel-traces {
    display: grid;
    gap: 0.95rem;
    min-height: 7rem;
    align-content: center;
  }

  .panel-traces span {
    display: block;
    height: 1px;
    position: relative;
    background: linear-gradient(90deg, transparent, rgba(88, 129, 132, 0.88), rgba(181, 148, 97, 0.88), transparent);
  }

  .panel-traces span:nth-child(2) {
    transform: translateX(1.4rem);
  }

  .panel-traces span:nth-child(3) {
    transform: translateX(2.6rem);
  }

  .panel-traces span::after {
    content: "";
    position: absolute;
    right: 18%;
    top: 50%;
    width: 0.6rem;
    height: 0.6rem;
    transform: translateY(-50%);
    border-radius: 999px;
    background: var(--wayweft-brass);
    box-shadow: 0 0 0 0.25rem rgba(181, 148, 97, 0.12);
  }

  .panel-copy h2 {
    font-size: clamp(1.8rem, 4vw, 2.7rem);
    line-height: 1.05;
    max-width: 13ch;
  }

  .feature-grid {
    display: grid;
    gap: 1rem;
    margin-top: 2rem;
  }

  .feature-grid article {
    padding: 1.35rem;
    border-radius: 1.2rem;
  }

  .feature-grid h3 {
    font-size: 1.5rem;
    margin-bottom: 0.75rem;
  }

  .command-band {
    display: grid;
    gap: 1rem;
    align-items: center;
    margin-top: 2rem;
    padding: 1.35rem 1.4rem;
    border-radius: 1.4rem;
  }

  .command-band pre {
    margin: 0;
    overflow-x: auto;
    padding: 1rem 1.1rem;
    border-radius: 1rem;
    background: #20263e;
    color: #f7f1e7;
  }

  @media (min-width: 860px) {
    .hero-grid {
      grid-template-columns: minmax(0, 1.1fr) minmax(360px, 0.8fr);
      gap: 2.5rem;
      min-height: 64vh;
    }

    .feature-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .command-band {
      grid-template-columns: 0.9fr 1.1fr;
    }
  }

  @media (max-width: 699px) {
    .landing-header {
      align-items: flex-start;
      flex-direction: column;
    }

    .landing-main {
      padding-top: 2rem;
    }
  }
</style>
